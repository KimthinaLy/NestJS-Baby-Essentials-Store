<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('./header_meta') %>
  <script defer src="https://unpkg.com/@alpinejs/mask@3.x.x/dist/cdn.min.js"></script>
  <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <link rel="stylesheet" href="https://unpkg.com/primeicons/primeicons.css">
  <title>Staff Portal | Baby Essential</title>
</head>
<body class="bg-slate-50 font-sans antialiased" x-data="{ sidebarOpen: true }">

  <div class="flex h-screen overflow-hidden">
    
    <aside 
      :class="sidebarOpen ? 'w-64' : 'w-20'" 
      class="bg-slate-900 text-slate-300 flex flex-col transition-all duration-300 ease-in-out border-r border-slate-800 shrink-0"
    >
      <div class="h-16 flex items-center px-6 bg-slate-950/50 shrink-0">
        <img src="/images/logo2.png" class="h-8" alt="Logo">
        <span x-show="sidebarOpen" class="ml-3 font-bold text-white tracking-tight truncate">STAFF PANEL</span>
      </div>

      <nav class="flex-1 overflow-y-auto py-6 px-3 space-y-2">
        <%- include('./staff_menu') %>
      </nav>

      <div class="p-4 bg-slate-950/30 border-t border-slate-800">
        <div class="flex items-center p-2 rounded-lg mb-2" x-show="sidebarOpen">
          <div class="w-8 h-8 rounded-full bg-indigo-500 flex items-center justify-center text-white font-bold text-xs">Acc</div>
          <div class="ml-3">
            <p class="text-xs font-semibold text-white">Staff</p>
            <p class="text-[10px] text-slate-500">Store Manager</p>
          </div>
        </div>
        <form action="/auth/logout" method="Post">
          <button class="flex items-center w-full px-3 py-2 text-sm text-slate-400 hover:bg-red-500/10 hover:text-red-500 rounded-lg transition-all">
            <i class="pi pi-sign-out"></i>
            <span x-show="sidebarOpen" class="ml-3">Sign Out</span>
          </button>
        </form>
      </div>
    </aside>

    <div class="flex-1 flex flex-col overflow-hidden">
      
      <header class="h-16 bg-white border-b border-slate-200 flex items-center justify-between px-8 shrink-0 z-10">
        <div class="flex items-center gap-6">
          <button @click="sidebarOpen = !sidebarOpen" class="p-2 rounded-md hover:bg-slate-100 text-slate-500 transition-colors">
            <i class="pi pi-bars text-lg"></i>
          </button>
          <nav class="hidden md:flex items-center text-sm text-slate-400 space-x-2">
            <span>Staff</span>
            <i class="pi pi-angle-right text-[10px]"></i>
            <span class="text-slate-900 font-medium"><%= typeof title !== 'undefined' ? title : 'Dashboard' %></span>
          </nav>
        </div>

        <div class="flex items-center gap-4">
          <button class="p-2 text-slate-400 hover:text-indigo-600 relative">
            <i class="pi pi-bell"></i>
            <span class="absolute top-2 right-2 w-2 h-2 bg-red-500 rounded-full border-2 border-white"></span>
          </button>
        </div>
      </header>

      <main class="flex-1 overflow-auto p-8">
        <div class="max-w-7xl mx-auto">
