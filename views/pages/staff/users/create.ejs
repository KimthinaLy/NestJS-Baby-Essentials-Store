<%- include('../../../partials/staff_shell_top', { title: 'Create Product' }) %>

  <div class="max-w-4xl mx-auto">
    <div class="mb-4">
      <a href="/staff/users"
        class="text-slate-500 hover:text-indigo-600 text-sm font-medium flex items-center gap-2 transition-colors">
        <i class="pi pi-arrow-left text-xs"></i> Back to User Management
      </a>
    </div>

    <form action="/staff/users/create" method="POST"
      class="bg-white shadow-xl rounded-2xl overflow-hidden border border-slate-200">

      <div class="bg-slate-50 px-8 py-4 border-b border-slate-200 flex justify-between items-center">
        <h3 class="text-lg font-bold text-slate-700 uppercase tracking-wider text-sm">Account Information</h3>
        <div class="p-2 bg-indigo-100 rounded-lg">
          <i class="pi pi-user text-indigo-600"></i>
        </div>
      </div>

      <div class="p-8 space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-semibold text-slate-600 mb-2">Full Name</label>
            <input type="text" name="fullName" required placeholder="John Doe"
              class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none transition-all">
          </div>

          <div>
            <label class="block text-sm font-semibold text-slate-600 mb-2">Account Phone</label>
            <input type="text" name="phone" x-data x-mask="(999) 999-9999" placeholder="(555) 555-5555"
              class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none transition-all">
          </div>

          <div>
            <label class="block text-sm font-semibold text-slate-600 mb-2">Role</label>
            <select name="role"
              class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white outline-none focus:ring-2 focus:ring-indigo-500">
              <% roles.forEach(role=> { %>
                <option value="<%= role %>">
                  <%= role %>
                </option>
                <% }) %>
            </select>
          </div>

          <div>
            <label class="block text-sm font-semibold text-slate-600 mb-2">Email Address</label>
            <input type="email" name="email" required placeholder="example@mail.com"
              class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none">
          </div>

          <div>
            <label class="block text-sm font-semibold text-slate-600 mb-2">Initial Password</label>
            <input type="password" name="password" required placeholder="Min 5 characters"
              class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none">
          </div>
        </div>
      </div>

      <div class="bg-slate-50 px-8 py-4 border-y border-slate-200 flex justify-between items-center">
        <h3 class="text-lg font-bold text-slate-700 uppercase tracking-wider text-sm">Primary Address</h3>
        <div class="p-2 bg-pink-100 rounded-lg">
          <i class="pi pi-map-marker text-pink-600"></i>
        </div>
      </div>

      <div class="p-8 space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-semibold text-slate-600 mb-2">Receiver Name</label>
            <input type="text" name="address[receiverName]" required placeholder="Recipient's Name"
              class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none">
          </div>

          <div>
            <label class="block text-sm font-semibold text-slate-600 mb-2">Contact Phone (Shipping)</label>
            <input type="text" name="address[phone]" x-data x-mask="(999) 999-9999" placeholder="(555) 555-5555"
              class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none transition-all">
          </div>
        </div>

        <div>
          <label class="block text-sm font-semibold text-slate-600 mb-2">Street Address</label>
          <input type="text" name="address[street]" required placeholder="Street, Apartment, Suite..."
            class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none">
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div>
            <label class="block text-sm font-semibold text-slate-600 mb-2">City</label>
            <input type="text" name="address[city]" required placeholder="City"
              class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none">
          </div>

          <div>
            <label class="block text-sm font-semibold text-slate-600 mb-2">Province</label>
            <input type="text" name="address[province]" required placeholder="Province"
              class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none">
          </div>

          <div>
            <label class="block text-sm font-semibold text-slate-600 mb-2">Postal Code</label>
            <input type="text" name="address[postalCode]" required placeholder="Postal Code"
              class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none">
          </div>
        </div>
      </div>

      <div class="px-8 py-6 bg-slate-50 border-t border-slate-200 flex justify-end gap-3">
        <a href="/staff/users" class="px-6 py-2.5 text-slate-600 font-medium hover:text-slate-800 transition-colors">
          Cancel
        </a>
        <button type="submit"
          class="px-10 py-2.5 bg-indigo-600 text-white font-bold rounded-xl shadow-lg shadow-indigo-100 hover:bg-indigo-700 transform active:scale-95 transition-all">
          Create User
        </button>
      </div>
    </form>
  </div>

  <%- include('../../../partials/staff_shell_bottom') %>