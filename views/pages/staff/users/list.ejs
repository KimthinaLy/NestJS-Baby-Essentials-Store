<%- include('../../../partials/staff_shell_top', { title: 'Inventory Management' }) %>

  <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
    <div class="p-6 border-b border-slate-100 flex justify-between items-center">
      <h2 class="text-xl font-bold text-slate-800">Product List</h2>
      <a href="/staff/users/create"
        class="bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm font-bold hover:bg-indigo-700 flex items-center gap-2">
        <i class="pi pi-plus"></i> New User
      </a>
    </div>

    <table class="w-full text-left border-collapse table-fixed min-w-[800px]">
      <thead class="bg-slate-50 text-slate-500 text-xs uppercase font-bold">
        <tr>
          <th class="w-[10%] px-6 py-4">User ID</th>
          <th class="w-[20%] px-6 py-4">User Name & Email</th>
          <th class="w-[12%] px-6 py-4">Role</th>
          <th class="w-[25%] px-6 py-4">Primary Address</th>
          <th class="w-[15%] px-6 py-4">Phone</th>
          <th class="w-[10%] px-6 py-4 text-right">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% if (users && users.length > 0) { %>
        <% users.forEach(user=> { %>
          <tr class="hover:bg-slate-50 transition-colors">
            <td class="px-6 py-4 font-medium text-slate-700">
              <div class="flex flex-col">
                  <span class="font-semibold text-slate-700"><%= user.id %></span>
                </div>
            </td>
            <td class="px-6 py-4 font-medium text-slate-700">
              <div class="flex flex-col">
                  <span class="font-semibold text-slate-700"><%= user.fullName %></span>
                  <span class="text-xs text-slate-400"><%= user.email %></span>
                </div>
            </td>
            <td class="px-6 py-4">
              <span class="text-[10px] px-2 py-1 rounded-full font-bold border 
                  <%= user.role === 'ADMIN' ? 'bg-purple-50 text-purple-600 border-purple-100' : 
                      user.role === 'MANAGER' ? 'bg-blue-50 text-blue-600 border-blue-100' :
                      user.role === 'EMPLOYEE' ? 'bg-green-50 text-green-600 border-green-100' : 
                      'bg-slate-50 text-slate-600 border-slate-100' %>">
                  <%= user.role %>
                </span>
            </td>
           <td class="px-6 py-4">
                <% if (user.addresses && user.addresses.length > 0) { %>
                  <div class="text-xs text-slate-600 leading-relaxed">
                    <p class="font-medium text-slate-700"><%= user.addresses[0].receiverName %></p>
                    <p class="truncate"><%= user.addresses[0].street %>, <%= user.addresses[0].city %>, <%= user.addresses[0].province%>, <%= user.addresses[0].postalCode %> %></p>
                  </div>
                <% } else { %>
                  <span class="text-slate-300 italic text-xs">No address provided</span>
                <% } %>
              </td>

           <td class="px-6 py-4 text-sm text-slate-600">
                <%= user.phone || (user.addresses && user.addresses[0] ? user.addresses[0].phone : 'N/A') %>
              </td>
           
            <td class="px-6 py-4 text-right space-x-2">
              <a href="/staff/users/<%= user.id %>/edit" class="text-indigo-600 hover:text-indigo-900"><i
                  class="pi pi-pencil"></i></a>
              <form action="/staff/users/<%= user.id %>/delete" method="POST" class="inline"
                onsubmit="return confirm('Delete this account?')">
                <button class="text-red-400 hover:text-red-600"><i class="pi pi-trash"></i></button>
              </form>
            </td>
          </tr>
          <% }) %>
          <% } else { %>
          <tr>
            <td colspan="5" class="px-6 py-10 text-center text-slate-400 italic">
              No users found.
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <%- include('../../../partials/staff_shell_bottom') %>