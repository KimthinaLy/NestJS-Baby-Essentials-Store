<%- include('../../../partials/staff_shell_top', { title: 'Inventory Management' }) %>

<div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
  <div class="p-6 border-b border-slate-100 flex justify-between items-center">
    <h2 class="text-xl font-bold text-slate-800">Product List</h2>
    <a href="/products/create" class="bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm font-bold hover:bg-indigo-700 flex items-center gap-2">
      <i class="pi pi-plus"></i> New Product
    </a>
  </div>

  <table class="w-full text-left border-collapse table-fixed min-w-[800px]">
    <thead class="bg-slate-50 text-slate-500 text-xs uppercase font-bold">
      <tr>
        <th class="w-[30%] px-6 py-4">Product Name</th>
        <th class="w-[15%] px-6 py-4">Category</th>
        <th class="w-[20%] px-6 py-4">Occasions</th>
        <th class="w-[10%] px-6 py-4">Price</th>
        <th class="w-[15%] px-6 py-4">Stock</th>
        <th class="w-[10%] px-6 py-4 text-right">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      <% products.forEach(product => { %>
        <tr class="hover:bg-slate-50 transition-colors">
          <td class="px-6 py-4 font-medium text-slate-700"><%= product.name %></td>
          <td class="px-6 py-4">
            <span class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded-full border border-slate-200">
              <%= product.category ? product.category.categoryName : 'No Category' %>
            </span>
          </td>
          <td class="px-6 py-4 text-sm text-slate-500">
            <% if (product.occasions && product.occasions.length > 0) { %>
              <%= product.occasions.map(occ => occ.name).join(', ') %>
            <% } else { %>
              <span class="text-slate-300 italic text-xs">None</span>
            <% } %>
          </td>
          <td class="px-6 py-4 text-slate-600">$<%= product.price %></td>
          <td class="px-6 py-4">
            <span class="px-2 py-1 rounded-md text-xs font-bold <%= product.qtyOnHand < 5 ? 'bg-red-100 text-red-600' : 'bg-green-100 text-green-600' %>">
              <%= product.qtyOnHand %> in stock
            </span>
          </td>
          <td class="px-6 py-4 text-right space-x-2">
            <a href="/products/<%= product.id %>/edit" class="text-indigo-600 hover:text-indigo-900"><i class="pi pi-pencil"></i></a>
            <form action="/products/<%= product.id %>/delete" method="POST" class="inline" onsubmit="return confirm('Delete this product?')">
              <button class="text-red-400 hover:text-red-600"><i class="pi pi-trash"></i></button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('../../../partials/staff_shell_bottom') %>