<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../../../partials/header_meta')%>
</head>

<body>
    <%- include('../../../partials/header') %>
        <main class="container mx-auto px-4 py-8 mt-16 min-h-screen">
            <div class="max-w-4xl mx-auto bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden">

                <div class="bg-indigo-50 px-8 py-6 border-b border-indigo-100">
                    <h1 class="text-2xl font-bold text-indigo-900 flex items-center gap-2">
                        <i class="pi pi-shopping-cart text-indigo-500"></i>
                        Shopping Cart
                    </h1>
                </div>

                <div class="p-8">
                    <% if (cart && cart.items && cart.items.length> 0) { %>
                        <div class="space-y-6">
                            <% cart.items.forEach(item=> { %>
                                <div
                                    class="flex flex-col md:flex-row items-center gap-6 p-4 rounded-2xl hover:bg-slate-50 transition-colors border border-transparent hover:border-slate-200">

                                    <div
                                        class="w-24 h-24 bg-pink-50 rounded-xl flex-shrink-0 flex items-center justify-center overflow-hidden">
                                        <img src="<%= item.product.displayImage %>" alt="<%= item.product.name %>"
                                            class="object-cover w-full h-full">
                                    </div>

                                    <div class="flex-grow text-center md:text-left">
                                        <h3 class="font-bold text-gray-800 text-lg">
                                            <%= item.product.name %>
                                        </h3>
                                        <p class="text-sm text-gray-500">Unit Price: $<%= item.product.price %>
                                        </p>
                                    </div>

                                    <div
                                        class="flex items-center bg-white border border-slate-200 rounded-full px-2 py-1 shadow-sm">
                                        <button type="button" onclick="updateCart('<%= item.product.id %>', 'decrease')"
                                            class="w-8 h-8 flex items-center justify-center text-indigo-600 hover:bg-indigo-50 rounded-full transition-colors">
                                            <i class="pi pi-minus text-xs"></i>
                                        </button>

                                        <span id="qty-<%= item.product.id %>"
                                            class="w-10 text-center font-bold text-gray-700">
                                            <%= item.quantity %>
                                        </span>

                                        <button type="button" onclick="updateCart('<%= item.product.id %>', 'increase')"
                                            class="w-8 h-8 flex items-center justify-center text-indigo-600 hover:bg-indigo-50 rounded-full transition-colors">
                                            <i class="pi pi-plus text-xs"></i>
                                        </button>
                                    </div>

                                    <div class="text-right min-w-[100px]">
                                        <span class="text-sm text-gray-400 block">Total</span>
                                        <span id="subtotal-<%= item.product.id %>"
                                            class="font-bold text-indigo-600 text-lg">
                                            $<%= (item.product.price * item.quantity).toFixed(2) %>
                                        </span>
                                    </div>

                                    <button type="button" onclick="removeFromCart('<%= item.product.id %>')"
                                        class="text-pink-400 hover:text-pink-600 p-2 transition-colors">
                                        <i class="pi pi-trash"></i>
                                    </button>
                                </div>
                                <% }) %>

                                    <hr class="border-slate-100 my-8">

                                    <div class="flex flex-col items-end gap-6">
                                        <div class="text-right">
                                            <span class="text-gray-500 mr-4">Order Total:</span>
                                            <span id="grand-total" class="text-3xl font-bold text-gray-900">
                                                $<%= cart.items.reduce((acc, item)=> acc + (item.product.price *
                                                    item.quantity), 0).toFixed(2) %>
                                            </span>
                                        </div>

                                        <div class="flex gap-4 w-full md:w-auto">
                                            <a href="/products"
                                                class="flex-1 md:flex-none text-center px-8 py-3 rounded-xl border border-slate-200 text-gray-600 font-semibold hover:bg-slate-50 transition-all">
                                                Continue Shopping
                                            </a>
                                            <a href="/orders/checkout"
                                                class="flex-1 md:flex-none text-center px-8 py-3 rounded-xl bg-indigo-600 text-white font-bold hover:bg-indigo-700 shadow-lg shadow-indigo-200 transition-all">
                                                Checkout Now
                                            </a>
                                        </div>
                                    </div>
                        </div>

                        <% } else { %>
                            <div class="text-center py-16">
                                <div
                                    class="bg-indigo-50 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6">
                                    <i class="pi pi-shopping-bag text-3xl text-indigo-300"></i>
                                </div>
                                <h2 class="text-xl font-bold text-gray-800 mb-2">Your cart is empty</h2>
                                <p class="text-gray-500 mb-8">Looks like you haven't added any baby essentials yet!</p>
                                <a href="/products"
                                    class="inline-block bg-indigo-600 text-white px-8 py-3 rounded-xl font-bold hover:bg-indigo-700 transition-all">
                                    Start Shopping
                                </a>
                            </div>
                            <% } %>
                </div>
            </div>
        </main>

        <%- include('../../../partials/footer') %>

            <script>
                async function updateCart(productId, action) {
                    try {
                        const response = await fetch('/cart/update', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ productId, action })
                        });

                        if (response.ok) {
                            const data = await response.json();

                            // 1. Update the quantity text
                            const qtyElement = document.getElementById(`qty-${productId}`);
                            const item = data.cart.items.find(i => i.product.id == productId);

                            if (item) {
                                qtyElement.innerText = item.quantity;
                                // 2. Update the subtotal for this item
                                document.getElementById(`subtotal-${productId}`).innerText =
                                    `$${(item.product.price * item.quantity).toFixed(2)}`;
                            }

                            // 3. Update the Grand Total
                            document.getElementById('grand-total').innerText = `$${data.total.toFixed(2)}`;
                        }
                    } catch (err) {
                        console.error("Failed to update cart", err);
                    }
                }

                async function removeFromCart(productId) {
                    if (!confirm('Remove this item?')) return;

                    const response = await fetch('/cart/remove', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ productId })
                    });

                    if (response.ok) {
                        location.reload(); // For removal, a reload is often cleaner to handle the "Empty Cart" state
                    }
                }
            </script>
</body>

</html>