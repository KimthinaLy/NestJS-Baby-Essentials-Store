<%- include('../../../partials/header_meta') %>
<body class="bg-slate-50 min-h-screen">
  <%- include('../../../partials/header') %>

  <main class="container mx-auto px-8 pt-8 pb-12 min-h-screen">
    <div class=" mx-auto px-8">
      
      <div class="flex items-center justify-between mb-8">
        <h1 class="text-3xl font-bold text-gray-800 flex items-center gap-3 ">
          <i class="pi pi-history text-indigo-500"></i>
          Order History
        </h1>
        <span class="bg-indigo-100 text-indigo-700 px-4 py-1 rounded-full text-sm font-medium whitespace-nowrap">
          Total Orders: <%= orders.length %>
        </span>
      </div>

      <div class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-x-auto">
        <table class="w-full text-left border-collapse min-w-[800px]">
          <thead>
            <tr class="bg-slate-50 border-b border-slate-100">
              <th class="w-[10%] px-6 py-4 text-sm font-bold text-gray-600 uppercase whitespace-nowrap">#</th>
              <th class="w-[10%] px-2 py-4 text-sm font-bold text-gray-600 uppercase whitespace-nowrap">Order ID</th>
              <th class="w-[15%] px-2 py-4 text-sm font-bold text-gray-600 uppercase whitespace-nowrap">Date</th>
              <th class="w-[15%] px-2 py-4 text-sm font-bold text-gray-600 uppercase">Amount</th>
              <th class="w-[15%] px-2 py-4 text-sm font-bold text-gray-600 uppercase whitespace-nowrap">Order Status</th>
              <th class="w-[15%] px-2 py-4 text-sm font-bold text-gray-600 uppercase whitespace-nowrap">Payment Status</th>
              <th class="w-[20%] px-2 py-4 text-sm font-bold text-gray-600 uppercase text-center whitespace-nowrap">Action</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-50">
            <% if (orders && orders.length > 0) { %>
              <% orders.forEach((order, i) => { %>
                <tr class="hover:bg-indigo-50/30 transition-colors">
                  <td class="px-6 py-5 text-gray-500 font-medium"><%= i + 1 %></td>
                  <td class="px-2 py-5">
                    <span class="font-mono text-sm text-indigo-600 font-semibold">#<%= order.order_id %></span>
                  </td>
                  <td class="px-2 py-5 text-gray-600 text-sm">
                    <%= new Date(order.order_date).toLocaleDateString() %>
                  </td>
                  <td class="px-2 py-5 font-bold text-gray-900">
                    $<%= parseFloat(order.total_amount).toFixed(2) %>
                  </td>
                  <td class="px-2 py-5">
                    <% 
                      let statusClass = "bg-gray-100 text-gray-600";
                      if(order.order_status === 'COMPLETED') statusClass = "bg-green-100 text-green-700";
                      if(order.order_status === 'PENDING') statusClass = "bg-amber-100 text-amber-700";
                      if(order.order_status === 'CANCELLED') statusClass = "bg-pink-100 text-pink-700";
                    %>
                    <span class="<%= statusClass %> px-3 py-1 rounded-full text-[11px] font-bold uppercase tracking-tight">
                      <%= order.order_status %>
                    </span>
                  </td>
                  <td class="px-2 py-5">
                    <% 
                      let statusClass2 = "bg-green-100 text-green-700";
                      if(order.payment_status === 'UNPAID') statusClass2 = "bg-pink-100 text-pink-700";
                    %>
                    <span class="<%= statusClass2 %> px-3 py-1 rounded-full text-[11px] font-bold uppercase tracking-tight">
                      <%= order.payment_status %>
                    </span>
                  </td>
                  <td class="px-2 py-5 text-center">
                    <a href="/orders/<%= order.order_id %>" class="inline-flex items-center gap-2 text-indigo-600 hover:text-indigo-800 font-bold text-sm">
                      <span>Details</span>
                      <i class="pi pi-angle-right"></i>
                    </a>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="7" class="px-6 py-20 text-center">
                  <div class="flex flex-col items-center">
                    <i class="pi pi-shopping-cart text-4xl text-slate-200 mb-4"></i>
                    <p class="text-gray-400">You haven't placed any orders yet.</p>
                    <a href="/products" class="mt-4 text-indigo-600 font-bold hover:underline">Start Shopping</a>
                  </div>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
      
    </div>
  </main>

  <%- include('../../../partials/footer') %>
</body>