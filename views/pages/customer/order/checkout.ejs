<%- include('../../../partials/header_meta') %>

  <body class="bg-slate-50 min-h-screen">
    <%- include('../../../partials/header') %>

      <main class="container mx-auto px-4 py-12 mt-16">

        <% if (typeof error !=='undefined' && error) { %>
          <div class="mb-6 p-4 bg-red-50 border-l-4 border-red-500 text-red-700 text-sm rounded-r-lg">
            <p class="font-bold">
              <%= error%>
            </p>
          </div>
          <% } %>
            <form action="/orders/place" method="POST">
              <div class="max-w-5xl mx-auto">
                <h1 class="text-3xl font-bold text-gray-800 mb-8 flex items-center gap-3">
                  <i class="pi pi-check-circle text-indigo-500"></i>
                  Checkout
                </h1>

                <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

                  <div class="lg:col-span-2 space-y-6">

                    <div class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden">
                      <div class="bg-indigo-50 px-8 py-4 border-b border-indigo-100 flex justify-between items-center">
                        <h2 class="text-lg font-bold text-indigo-900 flex items-center gap-2">
                          <i class="pi pi-map-marker"></i> Delivery Address
                        </h2>
                        <a href="#" class="text-sm text-indigo-600 hover:underline">Change Address</a>
                      </div>

                      <div class="p-8">
                        <% if (address) { %>
                          <input type="number" hidden name="addressId" value="<%= address.id %>">
                          <div class="space-y-2 text-gray-700">
                            <p class="font-bold text-xl text-gray-900">
                              <%= address.receiverName %>
                            </p>
                            <p class="flex items-center gap-2">
                              <i class="pi pi-phone text-gray-400"></i>
                              <%= address.phone %>
                            </p>
                            <p class="flex items-start gap-2 pt-2 text-gray-600">
                              <i class="pi pi-home mt-1 text-gray-400"></i>
                              <span>
                                <%= address.street %>, <%= address.city %>,<br>
                                    <%= address.province %>, <%= address.postalCode %>
                              </span>
                            </p>
                          </div>
                          <% } else { %>
                            <div class="text-center py-4">
                              <p class="text-pink-500 mb-4">No delivery address found.</p>
                              <a href="#" class="bg-indigo-600 text-white px-6 py-2 rounded-xl text-sm font-bold">Add
                                Address</a>
                            </div>
                            <% } %>
                      </div>
                    </div>

                    <div class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden">
                      <div class="bg-slate-50 px-8 py-4 border-b border-slate-100">
                        <h2 class="text-lg font-bold text-gray-800 flex items-center gap-2">
                          <i class="pi pi-credit-card"></i> Payment Method
                        </h2>
                      </div>
                      <div class="p-8">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                          <label
                            class="relative flex items-center p-4 border-2 border-indigo-500 bg-indigo-50 rounded-2xl cursor-pointer">
                            <input type="radio" name="payment" value="cod" checked
                              class="w-4 h-4 text-indigo-600 focus:ring-indigo-500">
                            <span class="ml-4 font-bold text-indigo-900">Cash on Delivery</span>
                            <i class="pi pi-wallet ml-auto text-indigo-500 text-xl"></i>
                          </label>

                          <label
                            class="relative flex items-center p-4 border-2 border-slate-100 rounded-2xl cursor-pointer hover:bg-slate-50">
                            <input type="radio" name="payment" value="transfer"
                              class="w-4 h-4 text-indigo-600 focus:ring-indigo-500">
                            <span class="ml-4 font-bold text-gray-700">Bank Transfer</span>
                            <i class="pi pi-building ml-auto text-gray-400 text-xl"></i>
                          </label>
                        </div>
                      </div>
                    </div>
                  </div>

                  <div class="lg:col-span-1">
                    <div class="bg-white rounded-3xl shadow-lg border border-slate-100 sticky top-24">
                      <div class="p-8">
                        <h2 class="text-xl font-bold text-gray-800 mb-6">Order Summary</h2>

                        <div class="space-y-4 mb-6 max-h-64 overflow-y-auto pr-2 custom-scrollbar">
                          <% cart.items.forEach(item=> { %>
                            <div class="flex items-center gap-4 py-2">
                              <div class="w-12 h-12 bg-slate-100 rounded-lg flex-shrink-0 overflow-hidden">
                                <img src="<%= item.product.displayImage %>" class="w-full h-full object-cover">
                              </div>
                              <div class="flex-grow min-w-0">
                                <p class="text-sm font-bold text-gray-800 truncate">
                                  <%= item.product.name %>
                                </p>
                                <p class="text-xs text-gray-500">Qty: <%= item.quantity %>
                                </p>
                              </div>
                              <p class="text-sm font-semibold text-gray-900">$<%= (item.product.price *
                                  item.quantity).toFixed(2) %>
                              </p>
                            </div>
                            <% }) %>
                        </div>

                        <div class="border-t border-slate-100 pt-6 space-y-3">
                          <div class="flex justify-between text-gray-500">
                            <span>Subtotal</span>
                            <span>$<%= total.toFixed(2) %></span>
                          </div>
                          <div class="flex justify-between text-gray-500">
                            <span>Shipping</span>
                            <span class="text-green-500 font-medium">FREE</span>
                          </div>
                          <div
                            class="flex justify-between text-xl font-bold text-gray-900 pt-2 border-t border-slate-50">
                            <span>Total</span>
                            <span class="text-indigo-600">$<%= total.toFixed(2) %></span>
                          </div>
                        </div>

                        <div class="mt-8">
                          <button type="submit"
                            class="w-full bg-indigo-600 text-white py-4 rounded-2xl font-bold text-lg hover:bg-indigo-700 shadow-xl shadow-indigo-200 transition-all flex items-center justify-center gap-2">
                            Place Order
                            <i class="pi pi-arrow-right text-sm"></i>
                          </button>
                        </div>
                      </div>
            </form>

            <p class="text-[10px] text-gray-400 text-center mt-4">
              By placing an order, you agree to our terms and conditions.
            </p>
            </div>
            </div>
            </div>

            </div>
            </div>
      </main>

      <%- include('../../../partials/footer') %>
  </body>